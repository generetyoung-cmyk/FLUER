# ── FLUER Protocol — API Gateway Environment Variables ────────
# Copy to .env and fill in real values

# ── Server ────────────────────────────────────────────────────
BIND_ADDR=0.0.0.0:8080
RUST_LOG=fluer_api=info,tower_http=warn
FRONTEND_URL=https://fluer.io

# ── Solana ────────────────────────────────────────────────────
SOLANA_CLUSTER=mainnet-beta
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=your_helius_api_key

# ── Database (PostgreSQL + TimescaleDB) ───────────────────────
# docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=secret timescale/timescaledb-ha:pg16-latest
DATABASE_URL=postgresql://postgres:secret@localhost:5432/fluer

# ── Cache (Redis) ─────────────────────────────────────────────
# docker run -d -p 6379:6379 redis:7-alpine
REDIS_URL=redis://127.0.0.1:6379

# ── Program IDs ───────────────────────────────────────────────
LAUNCHPAD_PROGRAM_ID=
PERP_ENGINE_PROGRAM_ID=
PREDICTION_PROGRAM_ID=

# ── Token ─────────────────────────────────────────────────────
FLUER_MINT=

# ── IPFS (Pinata) ─────────────────────────────────────────────
# Get from https://app.pinata.cloud/developers/api-keys
PINATA_JWT=your_pinata_jwt_here

# ── Price feeds ───────────────────────────────────────────────
PYTH_ENDPOINT=https://hermes.pyth.network
# SOL/USD Pyth price feed ID (mainnet)
SOL_USD_PYTH_FEED=0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d

# ── PumpPortal (Phase 1 launchpad) ────────────────────────────
# Optional — for priority fee customization
PUMPPORTAL_API_KEY=

# ── Yellowstone gRPC (for event indexing) ────────────────────
# Get from Helius or Triton One
YELLOWSTONE_GRPC_URL=https://grpc.mainnet.helius-rpc.com
YELLOWSTONE_GRPC_TOKEN=your_token_here

# ── Admin ─────────────────────────────────────────────────────
ADMIN_WALLET=your_admin_wallet_pubkey
