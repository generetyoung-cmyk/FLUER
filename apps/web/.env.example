# ── FLUER Protocol — Web App Environment Variables ────────────
# Copy to .env.local and fill in real values
# NEVER commit .env.local to git

# ── Solana RPC (Helius mainnet recommended) ───────────────────
# Get from https://dev.helius.xyz
NEXT_PUBLIC_HELIUS_API_KEY=your_helius_api_key_here
NEXT_PUBLIC_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
NEXT_PUBLIC_HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# ── FLUER Backend API ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.fluer.io
NEXT_PUBLIC_WS_URL=wss://api.fluer.io/ws

# ── Program IDs (set after deployment) ───────────────────────
NEXT_PUBLIC_LAUNCHPAD_PROGRAM_ID=
NEXT_PUBLIC_PERP_ENGINE_PROGRAM_ID=
NEXT_PUBLIC_PREDICTION_PROGRAM_ID=
NEXT_PUBLIC_FLUER_TOKEN_PROGRAM_ID=

# ── $FLUER token mint ─────────────────────────────────────────
NEXT_PUBLIC_FLUER_MINT=
