{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_WS_URL",
    "NEXT_PUBLIC_HELIUS_RPC_URL",
    "NEXT_PUBLIC_HELIUS_API_KEY",
    "NEXT_PUBLIC_HELIUS_WS_URL",
    "NEXT_PUBLIC_LAUNCHPAD_PROGRAM_ID",
    "NEXT_PUBLIC_PERP_ENGINE_PROGRAM_ID",
    "NEXT_PUBLIC_PREDICTION_PROGRAM_ID",
    "NEXT_PUBLIC_FLUER_TOKEN_PROGRAM_ID",
    "NEXT_PUBLIC_FLUER_MINT",
    "NEXT_PRIVATE_TARGET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "outputs": []
    },
    "test": {
      "outputs": []
    }
  }
}
