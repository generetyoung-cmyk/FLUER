{
  "name": "@fluer/sdk",
  "version": "1.0.0",
  "description": "FLUER Protocol TypeScript SDK — interact with launchpad, perps, and predictions",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./launchpad": {
      "import": "./dist/launchpad.mjs",
      "require": "./dist/launchpad.js",
      "types": "./dist/launchpad.d.ts"
    },
    "./perp": {
      "import": "./dist/perp.mjs",
      "require": "./dist/perp.js",
      "types": "./dist/perp.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/launchpad.ts src/perp.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.98.0",
    "@solana/spl-token": "^0.4.9",
    "bn.js": "^5.2.1",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "@types/bn.js": "^5.1.6"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.x",
    "@coral-xyz/anchor": "^0.30.x"
  }
}
